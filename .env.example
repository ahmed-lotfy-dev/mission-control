# ── AI Image Generation API Keys ──

# OpenRouter (Gemini 2.5 Flash Image, GPT-5 Image Mini, etc.)
# Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=orai-CHANGE_ME

# NVIDIA NIM (Qwen Image, Qwen Image Edit — free tier at build.nvidia.com)
# Get key from https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-CHANGE_ME

# Google Gemini API (Imagen 3 — free tier: 1500 requests/day)
# Get key from https://aistudio.google.com/apikey
GEMINI_API_TOKEN=CHANGE_ME

# Cloudflare Workers AI (FLUX.1 Schnell, SDXL — free daily quota >12M tokens)
# Get Account ID from dash.cloudflare.com > Workers AI
# Get API Token from dash.cloudflare.com > Profile > API Tokens > Create Token (Workers AI:Read)
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=CHANGE_ME

# ── Cloudflare R2 Storage (image backup & gallery) ──
# Create bucket at dash.cloudflare.com > R2 > Create Bucket
# Get API Token at dash.cloudflare.com > Profile > API Tokens > Create Token (R2:Edit)
# Use the same CLOUDFLARE_ACCOUNT_ID as above
R2_ACCOUNT_ID=SAME_AS_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY
R2_BUCKET_NAME=mission-control-images